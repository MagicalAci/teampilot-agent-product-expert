{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://teampilot/product-expert/eval-dataset-case.schema.json",
  "title": "Eval Dataset Case",
  "description": "评测集单条用例（JSONL 一行一条）。配合 scripts/run_eval.py 与 scripts/aggregate_eval_dataset.py 使用。",
  "type": "object",
  "required": ["id", "bucket", "input", "assertions"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识",
      "minLength": 1
    },
    "bucket": {
      "type": "string",
      "description": "四桶之一：生产样本/对抗/边界/失败回放",
      "enum": ["production", "adversarial", "edge", "failure_replay"]
    },
    "route": {
      "type": "string",
      "description": "意图/子任务路由，用于分路由统计"
    },
    "input": {
      "description": "被测服务的输入（字符串或结构化对象）",
      "type": ["string", "object", "array"]
    },
    "output": {
      "type": "string",
      "description": "被测服务对 input 的实际输出（单次）。评测对象。"
    },
    "outputs": {
      "type": "array",
      "description": "多次尝试的输出列表，用于计算 pass@k / pass^k。与 output 二选一。",
      "items": { "type": "string" }
    },
    "assertions": {
      "type": "array",
      "description": "断言列表，≥1。能用规则判的优先用规则 grader。",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "contains",
              "not_contains",
              "equals",
              "regex",
              "json_valid",
              "json_schema_keys",
              "max_length",
              "min_length",
              "judge"
            ]
          },
          "value": {
            "description": "断言参数：子串/正则/键名数组/长度阈值等",
            "type": ["string", "number", "array"]
          },
          "dimension": {
            "type": "string",
            "description": "归属维度，用于分维度通过率（如 accuracy/safety/format）"
          },
          "min_score": {
            "type": "number",
            "description": "judge 断言：达标分阈值"
          },
          "rubric": {
            "type": "string",
            "description": "judge 断言：评分量规（或量规文件路径）"
          }
        }
      }
    },
    "reference": {
      "type": "string",
      "description": "可选标准答案（gold），供 reference-based judge 用"
    },
    "weight": {
      "type": "number",
      "description": "用例权重，默认 1",
      "minimum": 0
    },
    "date_added": {
      "type": "string",
      "description": "加入日期 YYYY-MM-DD，用于季度复审",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
